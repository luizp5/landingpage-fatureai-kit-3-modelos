# Template Variant
VITE_TEMPLATE_VARIANT=template3

# Configurações da Empresa
VITE_COMPANY_NAME=Poupe AI
VITE_PAGE_TITLE=Poupe AI - Controle Total das Suas Finanças
VITE_PAGE_DESCRIPTION=Gerencie receitas e despesas pelo App ou WhatsApp. Dashboard completo, metas financeiras e relatórios detalhados. Comece grátis!

# URLs das Imagens
VITE_LOGO_URL=https://demo-app.poupeja.com/api/assets/system/logo?v=1759949777603
VITE_FAVICON_URL=https://demo-app.poupeja.com/api/assets/system/favicon?v=1759949756731
VITE_WHATSAPP_PREVIEW_URL=https://demo-app.poupeja.com/api/assets/system/favicon?v=1759949756731


# Contato de Suporte
VITE_SUPPORT_PHONE=+55 (11) 99999-8888
VITE_SUPPORT_EMAIL=suporte@poupeai.com.br
VITE_SUPPORT_WHATSAPP=+551199998888

# Preços dos Planos
VITE_PLAN_PRICE_MONTHLY=29,97
VITE_PLAN_PRICE_ANNUAL=179,00

# URLs de Pagamento dos Planos (Hotmart, Asaas, Kiwify, etc.)
# Deixe em branco para usar WhatsApp como fallback
VITE_MONTHLY_PLAN_URL=
VITE_ANNUAL_PLAN_URL=

# Features dos Planos (separadas por vírgula)
VITE_PLAN_FEATURES_MONTHLY=Mensagens por texto,Mensagens em Áudio e imagem,Limite por categoria,Relatórios de gastos,Sem fidelidade
VITE_PLAN_FEATURES_ANNUAL=Mensagens por texto,Mensagens em Áudio e imagem,Limite por categoria,Relatórios completos,Metas financeiras,Suporte prioritário

# Trackeamento Facebook
#VITE_PIXEL_FACEBOOK_ENABLE_DEV=true
VITE_PIXEL_FACEBOOK=1234567890123456
VITE_PIXEL_FACEBOOK_REQUIRE_CONSENT=true

# Configuração do Google Tag Manager
# ID do container do GTM no formato "GTM-XXXXXX" (substituir pelo real)
GTM_ID=GTM-XXXXXX
# Ambiente da aplicação: 'development' ou 'production'
NODE_ENV=production
# Permitir carregar o GTM em desenvolvimento
GTM_ENABLE_DEV=true  